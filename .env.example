# ═══════════════════════════════════════════════
#  GALAXY SINKS — Variables d'environnement
#  Copie ce fichier en .env et remplis les valeurs
# ═══════════════════════════════════════════════

# ── Discord OAuth ──
# Récupère ces valeurs sur https://discord.com/developers/applications
DISCORD_CLIENT_ID=TON_CLIENT_ID_ICI
DISCORD_CLIENT_SECRET=TON_CLIENT_SECRET_ICI
DISCORD_BOT_TOKEN=TON_BOT_TOKEN_ICI
DISCORD_GUILD_ID=TON_SERVER_ID_ICI       # ID de ton serveur Galaxy Sinks Discord

# ── URLs ──
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:3000
# En production remplace par ton domaine Railway :
# FRONTEND_URL=https://galaxy-sinks.railway.app
# BACKEND_URL=https://galaxy-sinks.railway.app

# ── Discord OAuth Redirect ──
DISCORD_REDIRECT_URI=http://localhost:3000/auth/discord/callback
# En production :
# DISCORD_REDIRECT_URI=https://galaxy-sinks.railway.app/auth/discord/callback

# ── Supabase ──
# Récupère ces valeurs sur https://supabase.com → Settings → API
SUPABASE_URL=https://XXXXXXXX.supabase.co
SUPABASE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...TON_ANON_KEY

# ── Tracker Network (stats Rocket League) ──
# Clé gratuite sur https://tracker.gg/developers
TRACKER_API_KEY=TON_TRACKER_API_KEY_ICI

# ── Session ──
SESSION_SECRET=change_moi_par_une_longue_chaine_aleatoire_secrete

# ── Environnement ──
NODE_ENV=development
PORT=3000

# ═══════════════════════════════════════════════
#  IDs des rôles Discord de ton serveur Galaxy Sinks
#  Récupère-les : Discord → Paramètres serveur → Rôles → clic droit → Copier l'ID
# ═══════════════════════════════════════════════
DISCORD_ROLE_ADMIN=ID_DU_ROLE_ADMIN
DISCORD_ROLE_STAFF=ID_DU_ROLE_STAFF
DISCORD_ROLE_COACH=ID_DU_ROLE_COACH
DISCORD_ROLE_MEMBRE=ID_DU_ROLE_MEMBRE
